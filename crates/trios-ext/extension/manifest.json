{
  "manifest_version": 3,
  "name": "Trinity Agent Bridge",
  "version": "0.3.0",
  "description": "Trinity Agent Bridge \u2014 WASM sidepanel + MCP HTTP client",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:9105/*",
    "http://localhost:9105/*"
  ],
  "background": {
    "service_worker": "dist/bg-sw.js",
    "type": "module"
  },
  "action": {
    "default_title": "Trinity Agent Bridge",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' http://127.0.0.1:9105 http://127.0.0.1:9002 http://127.0.0.1:9200;"
  }
}
