{
  "manifest_version": 3,
  "name": "Trios Chrome Extension",
  "version": "0.1.0",
  "description": "Trinity Stack Law Compliant — Rust + WASM Chrome Extension with MCP bridge to trios-server",
  "permissions": [
    "sidePanel"
  ],
  "host_permissions": [
    "ws://localhost:9005/*"
  ],
  "background": {
    "service_worker": "dist/trios_ext_bg.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Trios Sidepanel"
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  }
}
