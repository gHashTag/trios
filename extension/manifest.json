{
  "manifest_version": 3,
  "name": "Trios — Queen Trinity Sidebar",
  "version": "0.1.0",
  "description": "Trios agent orchestrator sidebar panel",
  "permissions": ["sidePanel", "activeTab"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open Trios"
  }
}
