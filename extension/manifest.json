{
  "manifest_version": 3,
  "name": "Trinity Agent Bridge",
  "version": "1.0.0",
  "description": "Trinity Agent Bridge Chrome Extension - Issue #56",
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "ws://localhost:7474/*",
    "https://github.com/*",
    "https://claude.ai/*",
    "https://cursor.sh/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["src/content/claude-injector.ts"],
      "type": "module"
    },
    {
      "matches": ["https://github.com/*"],
      "js": ["src/content/github-injector.ts"],
      "type": "module"
    },
    {
      "matches": ["https://cursor.sh/*"],
      "js": ["src/content/cursor-injector.ts"],
      "type": "module"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "128": "icons/icon.svg"
    }
  },
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
